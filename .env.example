# ─────────────────────────────────────────────────────────────────────────────
# Supabase  (Project Settings → API, and → Database)
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# Public project URL and anon key — safe to expose to the browser (RLS protects the data).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — SERVER ONLY. Bypasses Row-Level Security. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres connection strings (Project Settings → Database → Connection string).
#   DATABASE_URL : pooled connection (port 6543, "Transaction" mode) — used by the app.
#   DIRECT_URL   : direct connection (port 5432)                     — used for migrations.
DATABASE_URL=postgresql://postgres.YOUR-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.YOUR-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ─────────────────────────────────────────────────────────────────────────────
# Google Places API (Lead Finder).  Google Cloud Console → APIs & Services.
# Enable "Places API (New)" and "Geocoding API", then create an API key.
# Server-side only — keep it secret and restrict it to those two APIs.
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-cloud-api-key

# ─────────────────────────────────────────────────────────────────────────────
# Anthropic / Claude (AI website copy).  console.anthropic.com → API Keys.
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional model overrides (defaults shown):
# ANTHROPIC_MODEL=claude-sonnet-5
# ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# ─────────────────────────────────────────────────────────────────────────────
# HeyGen (AI avatar videos) — app.heygen.com → Space Settings → API. OPTIONAL:
# without a key the Avatar Videos module runs in demo mode (sample clips, free).
# Pay-as-you-go; standard avatar generation ≈ $1 per minute of video.
# ─────────────────────────────────────────────────────────────────────────────
# HEYGEN_API_KEY=your-heygen-api-key

# ─────────────────────────────────────────────────────────────────────────────
# Platform admin: comma-separated emails that get the cross-tenant Admin view.
# Add YOUR email here to become the platform owner — no SQL needed.
# ─────────────────────────────────────────────────────────────────────────────
PLATFORM_ADMIN_EMAILS=you@example.com

# ─────────────────────────────────────────────────────────────────────────────
# Stripe (billing) — dashboard.stripe.com, use TEST mode keys.
# Price IDs are created for you by: node scripts/setup-stripe.mjs
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...
